---
import { getCollection } from 'astro:content'
import Desktop from '../components/Desktop'
import type { SiteData } from '../lib/commands'
import '../styles/terminal.css'
import '../styles/win98.css'
import '../styles/backgrounds.css'
import '../styles/matrix-rain.css'

const projectEntries = await getCollection('projects')
const postEntries = await getCollection('posts')
const noteEntries = await getCollection('notes')

const projects = projectEntries
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .map((p) => ({
    title: p.data.title,
    description: p.data.description,
    tags: p.data.tags,
    github: p.data.github,
    demo: p.data.demo,
    body: p.body ?? '',
  }))

const garden = [
  ...postEntries.map((p) => ({
    slug: p.id.replace(/\.md$/, ''),
    title: p.data.title,
    date: p.data.date.toISOString().slice(0, 10),
    tags: p.data.tags,
    type: 'post' as const,
    body: p.body ?? '',
  })),
  ...noteEntries.map((n) => ({
    slug: n.id.replace(/\.md$/, ''),
    title: n.data.title,
    date: n.data.date.toISOString().slice(0, 10),
    tags: n.data.tags,
    type: 'note' as const,
    body: n.body ?? '',
  })),
].sort((a, b) => b.date.localeCompare(a.date))

const siteData: SiteData = {
  about: `  Hi, I'm Lewis Liu.

  I'm an engineer who builds across domains — AI agent,
  bioinformatics infrastructure, and developer
  experience. I like systems that compose, contracts that hold, and
  software that earns its weight.

  Day job: software engineer at BGI Genomics (深圳华大基因) —
  workflow standardization across 10+ NGS pipelines, LLM-driven
  clinical interpretation, and prompt evaluation systems.

  After hours I ship open source: Bioinfoflow (agentic workflow
  platform), A-Share Sector Alpha Hunter, a Notion clone called Jotion, etc.

  2023 阿里云天池 · 生命科学赛道 冠军 + 创新奖.
  Co-author on Hum Genomics 18:114 (2024).`,

  skills: [
    {
      category: 'AI / LLM / Agents',
      items: [
        'LangChain',
        'Agent runtime',
        'Agent Harness',
        'Prompt engineering',
        'Eval',
        'RAG',
      ],
    },
    {
      category: 'Bioinformatics',
      items: [
        'Nextflow',
        'WDL / miniwdl',
        'Snakemake',
        'GATK4',
        'DeepVariant',
        'BWA',
        'NVIDIA Parabricks',
        'ACMG variant interpretation',
        'NGS pipeline standardization',
      ],
    },
    {
      category: 'Backend & Systems',
      items: [
        'Python',
        'FastAPI',
        'Docker',
        'Linux',
      ],
    },
    {
      category: 'Frontend',
      items: [
        'Next.js',
        'React',
        'TypeScript',
        'TailwindCSS',
        'shadcn-ui',
      ],
    },
    {
      category: 'Data',
      items: [
        'Streamlit',
        'Pandas',
        'AutoGluon',
      ],
    },
  ],

  projects,
  garden,

  contact: {
    email: 'lewis.gen.liu@gmail.com',
    github: 'lewismessthecode',
    twitter: 'leeeewisliu',
  },

  resume: `  Lewis Liu
  Software Engineer · AI Agent Systems · Bioinformatics Infra · Builder

  EXPERIENCE
  ──────────
  BGI Genomics (深圳华大基因) — 2022.07 to present
    Software Engineer / Bioinformatics Engineer

    · Standardized NGS workflows across 10+ business lines
      (Oncology, NIPT, WGS) — production stability +45%.
    · Led ACMG-based LLM clinical interpretation pipeline; designed
      end-to-end prompt eval system, +40% accuracy to expert level.
    · Fine-tuned LLaMA-7B & BioGPT on 10k HPO entries — validated
      medical-domain LLM adaptation, results near OSS SOTA at the time.

  SELECTED PROJECTS
  ──────────────────
  Bioinfoflow (2025–) — Local-first agentic bioinformatics workflow platform.

  RECOGNITION
  ────────────
  · 2023 Aliyun Tianchi Bio AI Challenge
    生命科学赛道 — 冠军 (1st) + 创新奖 (Innovation Award)
  · Wang T, ..., Liu Z et al. — Hum Genomics 18:114 (2024)
    Fast and accurate DNA-Seq variant calling workflow composed of
    LUSH toolkit. DOI: 10.1186/s40246-024-00666-w

  EDUCATION
  ──────────
  South China Agricultural University
  Molecular Biology · BSc + MSc · 2015 – 2022

  Open to remote opportunities and interesting problems.`,
}

// URL params handled client-side in Terminal component
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lewis Liu — Engineer · Builder · AI Agents · Bioinfo</title>
    <meta
      name="description"
      content="Lewis Liu — engineer building across AI agent, bioinformatics infrastructure, and developer experience. Open source, BGI Genomics, Tianchi 1st place."
    />
    <meta property="og:title" content="Lewis Liu — Engineer · Builder · AI Agents · Bioinfo · Data scientist" />
    <meta
      property="og:description"
      content="Engineer who works across AI agents, bioinformatics, and dev tools. Open source builder."
    />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Lewis Liu — Engineer · Builder" />
    <meta
      name="twitter:description"
      content="Engineer building across AI agents, bioinformatics, and dev experience."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Desktop client:load data={siteData} />
    <noscript>
      <div class="noscript-content">
        <h1>Lewis Liu</h1>
        <p>Engineer · Builder · AI Agents · Bioinformatics · Data scientist</p>
        <h2>About</h2>
        <p>
          Engineer who builds across AI agent, bioinformatics
          infrastructure, and developer experience.
          Software engineer at BGI Genomics. Open source builder.
        </p>
        <h2>Projects</h2>
        <ul>
          {projects.map((p) => (
            <li>
              <strong>{p.title}</strong> - {p.description}
            </li>
          ))}
        </ul>
        <h2>Blog</h2>
        <ul>
          {garden.map((g) => (
            <li>
              {g.date} - {g.title}
            </li>
          ))}
        </ul>
        <h2>Contact</h2>
        <p>Email: lewis.o.liu@gmail.com</p>
        <p>GitHub: github.com/lewismessthecode</p>
      </div>
    </noscript>
  </body>
</html>
